{
  "id": "code-refactor",
  "name": "Code Refactor",
  "version": "1.0.0",
  "description": "Refactor code safely with tests and style checks",
  "enabled": true,
  "useWhen": [
    "refactor",
    "cleanup",
    "improve code structure"
  ],
  "requiredTools": [
    "file.read",
    "file.write",
    "shell.run"
  ],
  "permissions": {
    "network": false,
    "fileSystem": true,
    "shell": true,
    "allowedPaths": [
      "src/**",
      "tests/**"
    ],
    "blockedCommands": [
      "rm -rf /",
      "git reset --hard"
    ],
    "maxToolCalls": 20
  },
  "entrypoints": {
    "plannerPrompt": "code-refactor/SKILL.md",
    "executorPrompt": "code-refactor/Workflows/Refactor.md"
  },
  "dependencies": [],
  "compatibility": {
    "assistantCore": ">=0.1.0 <1.0.0"
  },
  "overrideOf": null,
  "tags": [
    "code",
    "refactor"
  ]
}
