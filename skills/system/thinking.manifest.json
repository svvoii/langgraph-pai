{
  "id": "thinking",
  "name": "Thinking",
  "version": "1.0.0",
  "description": "Structured decomposition and deep analysis",
  "enabled": true,
  "useWhen": [
    "analyze",
    "decompose",
    "plan",
    "think"
  ],
  "requiredTools": [
    "reasoning"
  ],
  "permissions": {
    "network": false,
    "fileSystem": false,
    "shell": false,
    "allowedPaths": [],
    "blockedCommands": [],
    "maxToolCalls": 10
  },
  "entrypoints": {
    "plannerPrompt": "thinking/SKILL.md",
    "executorPrompt": "thinking/Workflows/FirstPrinciples.md"
  },
  "dependencies": [],
  "compatibility": {
    "assistantCore": ">=0.1.0 <1.0.0"
  },
  "overrideOf": null,
  "tags": [
    "analysis",
    "reasoning"
  ]
}
