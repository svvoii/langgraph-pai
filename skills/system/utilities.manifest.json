{
  "id": "utilities",
  "name": "Utilities",
  "version": "1.0.0",
  "description": "Execution helpers and tooling",
  "enabled": true,
  "useWhen": [
    "implement",
    "build",
    "generate",
    "create"
  ],
  "requiredTools": [
    "file.read",
    "file.write",
    "shell.run"
  ],
  "permissions": {
    "network": false,
    "fileSystem": true,
    "shell": true,
    "allowedPaths": [
      "src/**",
      "skills/**",
      "README.md"
    ],
    "blockedCommands": [
      "rm -rf /",
      "git reset --hard"
    ],
    "maxToolCalls": 15
  },
  "entrypoints": {
    "plannerPrompt": "utilities/SKILL.md",
    "executorPrompt": "utilities/Workflows/CreateSkill.md"
  },
  "dependencies": [],
  "compatibility": {
    "assistantCore": ">=0.1.0 <1.0.0"
  },
  "overrideOf": null,
  "tags": [
    "execution",
    "tooling"
  ]
}
